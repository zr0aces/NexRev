# AI provider selection: ollama | openrouter | litellm
AI_PROVIDER=ollama

# Shared fallback model (optional) used if provider-specific model is not set.
# Example: AI_MODEL=llama3.2 (for ollama) or AI_MODEL=openai/gpt-4o-mini (for openrouter via OPENROUTER_MODEL fallback)
AI_MODEL=

# Ollama (local)
# URL of your Ollama instance. When running via Docker Compose on Linux use
# host.docker.internal (added automatically via extra_hosts in docker-compose.yml).
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Model to use — must be pulled in Ollama first: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# OpenRouter (cloud)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_API_KEY=
# Fallback to openai/ model handler in LiteLLM.js if openrouter/ prefix is unsupported
OPENROUTER_OPENAI_FALLBACK=true

# LiteLLM proxy (self-hosted or managed)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MODEL=
LITELLM_MODEL_PREFIX=
LITELLM_API_KEY=

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# CORS / logging
# In production, set this to the exact browser origin(s) allowed to call the API.
# Use comma-separated origins if needed.
CORS_ORIGIN=http://localhost:8088
LOG_LEVEL=info

# Telegram Bot Token (optional) — get it from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=
REMINDER_TIMEZONE=Asia/Bangkok

# WebAuthn / Passkey configuration
# RP_ID must match the domain of your app (e.g. "example.com" in production; "localhost" for dev)
WEBAUTHN_RP_ID=localhost
# Human-readable name shown in the platform authenticator UI
WEBAUTHN_RP_NAME=NexRev
# Allowed origin(s) — must match the browser origin exactly. Comma-separated for multiple.
WEBAUTHN_ORIGIN=http://localhost:8088

# Application Version
NEXREV_VERSION=2026.5.17
