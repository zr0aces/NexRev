# Ollama — local AI inference
# URL of your Ollama instance. When running via Docker Compose on Linux use
# host.docker.internal (added automatically via extra_hosts in docker-compose.yml).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Model to use — must be pulled in Ollama first: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Telegram Bot Token (optional) — get it from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# Application Version
NEXREV_VERSION=2026.5.1
