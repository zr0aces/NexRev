{
  "name": "nexrev-backend",
  "version": "2026.5.6",
  "type": "module",
  "scripts": {
    "version:sync": "node ../scripts/sync-version.mjs",
    "predev": "npm run version:sync",
    "prebuild": "npm run version:sync",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:legacy": "tsx src/scripts/migrate-legacy.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "db:backup": "node scripts/db-backup-restore.mjs backup data/backups/nexrev-backup.sqlite3",
    "db:restore": "node scripts/db-backup-restore.mjs restore data/backups/nexrev-backup.sqlite3"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
